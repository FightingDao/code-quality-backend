generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model code_analyses {
  id                String         @id
  user_id           String
  project_id        String
  period_type       String         @db.VarChar(20)
  period_value      String         @db.VarChar(10)
  commit_count      Int
  insertions        Int
  deletions         Int
  files_changed     Int
  total_lines       Int
  code_lines        Int
  comment_lines     Int
  blank_lines       Int
  languages         Json?
  file_changes      Json?
  ai_quality_score  Decimal?       @db.Decimal(5, 2)
  ai_quality_report String?
  task_count        Int?
  created_at        DateTime       @default(now())
  updated_at        DateTime
  branch            String?        @db.VarChar(100)
  compare_version   String?        @db.VarChar(100)
  current_version   String?        @db.VarChar(100)
  projects          projects       @relation(fields: [project_id], references: [id])
  users             users          @relation(fields: [user_id], references: [id])
  code_issues       code_issues[]
  code_reviews      code_reviews[]

  @@unique([user_id, project_id, period_type, period_value])
}

model code_issues {
  id             String        @id
  analysis_id    String
  file_path      String        @db.VarChar(500)
  line_start     Int?
  line_end       Int?
  issue_type     String        @db.VarChar(50)
  severity       String        @db.VarChar(10)
  description    String
  suggestion     String?
  code_snippet   String?
  created_at     DateTime      @default(now())
  updated_at     DateTime
  code_example   String?
  committer_name String?       @db.VarChar(100)
  code_analyses  code_analyses @relation(fields: [analysis_id], references: [id])

  @@index([analysis_id])
  @@index([issue_type])
  @@index([severity])
}

model code_reviews {
  id                                     String        @id
  analysis_id                            String
  commit_hash                            String        @db.VarChar(40)
  commit_message                         String
  commit_branch                          String?       @db.VarChar(200)
  commit_date                            DateTime
  committer_id                           String
  committer_name                         String        @db.VarChar(100)
  reviewer_id                            String?
  reviewer_name                          String?       @db.VarChar(100)
  status                                 String        @db.VarChar(20)
  comments                               String?
  review_result                          String?
  reviewed_at                            DateTime?
  created_at                             DateTime      @default(now())
  updated_at                             DateTime
  code_analyses                          code_analyses @relation(fields: [analysis_id], references: [id])
  users_code_reviews_committer_idTousers users         @relation("code_reviews_committer_idTousers", fields: [committer_id], references: [id])
  users_code_reviews_reviewer_idTousers  users?        @relation("code_reviews_reviewer_idTousers", fields: [reviewer_id], references: [id])
}

model project_statistics {
  id                 String   @id
  project_id         String
  period_type        String   @db.VarChar(20)
  period_value       String   @db.VarChar(10)
  total_contributors Int
  total_commits      Int
  total_insertions   Int
  total_deletions    Int
  total_tasks        Int
  total_lines        Int
  avg_quality_score  Decimal? @db.Decimal(5, 2)
  created_at         DateTime @default(now())
  updated_at         DateTime
  ai_advantages      Json?
  ai_best_practices  Json?
  ai_common_issues   Json?
  ai_rating          String?  @db.VarChar(20)
  ai_suggestions     Json?
  projects           projects @relation(fields: [project_id], references: [id])

  @@unique([project_id, period_type, period_value])
}

model projects {
  id                 String               @id
  name               String               @db.VarChar(200)
  repository         String               @db.VarChar(500)
  description        String?
  team_id            String?
  tech_stack         Json?
  is_active          Boolean              @default(true)
  default_branch     String?              @db.VarChar(100)
  last_commit_at     DateTime?
  created_at         DateTime             @default(now())
  updated_at         DateTime
  code_analyses      code_analyses[]
  project_statistics project_statistics[]
  teams              teams?               @relation(fields: [team_id], references: [id])
}

model team_statistics {
  id                String   @id
  team_id           String
  period_type       String   @db.VarChar(20)
  period_value      String   @db.VarChar(10)
  total_members     Int
  active_members    Int
  total_commits     Int
  total_insertions  Int
  total_deletions   Int
  total_tasks       Int
  avg_quality_score Decimal? @db.Decimal(5, 2)
  created_at        DateTime @default(now())
  updated_at        DateTime
  ai_advantages     Json?
  ai_rating         String?  @db.VarChar(20)
  ai_suggestions    Json?
  ai_summary        String?
  teams             teams    @relation(fields: [team_id], references: [id])

  @@unique([team_id, period_type, period_value])
}

model teams {
  id              String            @id
  name            String            @db.VarChar(100)
  description     String?
  created_at      DateTime          @default(now())
  updated_at      DateTime
  leader_name     String?           @db.VarChar(50)
  projects        projects[]
  team_statistics team_statistics[]
  users           users[]
}

model users {
  id                                            String          @id
  username                                      String          @db.VarChar(50)
  email                                         String          @unique @db.VarChar(100)
  avatar                                        String?         @db.VarChar(500)
  team_id                                       String?
  git_username                                  String?         @db.VarChar(100)
  git_email                                     String?         @db.VarChar(100)
  is_active                                     Boolean         @default(true)
  created_at                                    DateTime        @default(now())
  updated_at                                    DateTime
  code_analyses                                 code_analyses[]
  code_reviews_code_reviews_committer_idTousers code_reviews[]  @relation("code_reviews_committer_idTousers")
  code_reviews_code_reviews_reviewer_idTousers  code_reviews[]  @relation("code_reviews_reviewer_idTousers")
  teams                                         teams?          @relation(fields: [team_id], references: [id])
}
