generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(100)
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  leaderName  String?         @map("leader_name") @db.VarChar(50)
  projects    Project[]
  statistics  TeamStatistic[]
  users       User[]

  @@map("teams")
}

model User {
  id               String         @id @default(uuid())
  username         String         @db.VarChar(50)
  email            String         @unique @db.VarChar(100)
  avatar           String?        @db.VarChar(500)
  teamId           String?        @map("team_id")
  gitUsername      String?        @map("git_username") @db.VarChar(100)
  gitEmail         String?        @map("git_email") @db.VarChar(100)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  codeAnalyses     CodeAnalysis[]
  committedReviews CodeReview[] @relation("CommittedReviews")
  reviewedBy       CodeReview[] @relation("ReviewedBy")
  team             Team?        @relation(fields: [teamId], references: [id])

  @@map("users")
}

model Project {
  id            String             @id @default(uuid())
  name          String             @db.VarChar(200)
  repository    String             @db.VarChar(500)
  description   String?
  teamId        String?            @map("team_id")
  techStack     Json?              @map("tech_stack")
  isActive      Boolean            @default(true) @map("is_active")
  defaultBranch String?            @map("default_branch") @db.VarChar(100)
  lastCommitAt  DateTime?          @map("last_commit_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  analyses   CodeAnalysis[]
  statistics ProjectStatistic[]
  team       Team?              @relation(fields: [teamId], references: [id])

  @@map("projects")
}

model CodeAnalysis {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  projectId       String       @map("project_id")
  periodType      String       @map("period_type") @db.VarChar(20)
  periodValue     String       @map("period_value") @db.VarChar(10)
  commitCount     Int          @map("commit_count")
  insertions      Int
  deletions       Int
  filesChanged    Int          @map("files_changed")
  totalLines      Int          @map("total_lines")
  codeLines       Int          @map("code_lines")
  commentLines    Int          @map("comment_lines")
  blankLines      Int          @map("blank_lines")
  languages       Json?
  fileChanges     Json?        @map("file_changes")
  aiQualityScore  Decimal?     @map("ai_quality_score") @db.Decimal(5, 2)
  aiQualityReport String?      @map("ai_quality_report")
  taskCount       Int?         @map("task_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  branch          String?      @db.VarChar(100)
  compareVersion  String?      @map("compare_version") @db.VarChar(100)
  currentVersion  String?      @map("current_version") @db.VarChar(100)
  project         Project      @relation(fields: [projectId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
  issues          CodeIssue[]
  reviews         CodeReview[]

  @@unique([userId, projectId, periodType, periodValue])
  @@map("code_analyses")
}

model CodeReview {
  id            String       @id @default(uuid())
  analysisId    String       @map("analysis_id")
  commitHash    String       @map("commit_hash") @db.VarChar(40)
  commitMessage String       @map("commit_message")
  commitBranch  String?      @map("commit_branch") @db.VarChar(200)
  commitDate    DateTime     @map("commit_date")
  committerId   String       @map("committer_id")
  committerName String       @map("committer_name") @db.VarChar(100)
  reviewerId    String?      @map("reviewer_id")
  reviewerName  String?      @map("reviewer_name") @db.VarChar(100)
  status        String       @db.VarChar(20)
  comments      String?
  reviewResult  String?      @map("review_result")
  reviewedAt    DateTime?    @map("reviewed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  analysis      CodeAnalysis @relation(fields: [analysisId], references: [id])
  committer     User         @relation("CommittedReviews", fields: [committerId], references: [id])
  reviewer      User?        @relation("ReviewedBy", fields: [reviewerId], references: [id])

  @@map("code_reviews")
}

model CodeIssue {
  id            String       @id @default(uuid())
  analysisId    String       @map("analysis_id")
  filePath      String       @map("file_path") @db.VarChar(500)
  lineStart     Int?         @map("line_start")
  lineEnd       Int?         @map("line_end")
  issueType     String       @map("issue_type") @db.VarChar(50)
  severity      String       @db.VarChar(10)
  description   String
  suggestion    String?
  codeSnippet   String?      @map("code_snippet")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  codeExample   String?      @map("code_example")
  committerName String?      @map("committer_name") @db.VarChar(100)
  analysis      CodeAnalysis @relation(fields: [analysisId], references: [id])

  @@index([analysisId])
  @@index([severity])
  @@index([issueType])
  @@map("code_issues")
}

model TeamStatistic {
  id              String   @id @default(uuid())
  teamId          String   @map("team_id")
  periodType      String   @map("period_type") @db.VarChar(20)
  periodValue     String   @map("period_value") @db.VarChar(10)
  totalMembers    Int      @map("total_members")
  activeMembers   Int      @map("active_members")
  totalCommits    Int      @map("total_commits")
  totalInsertions Int      @map("total_insertions")
  totalDeletions  Int      @map("total_deletions")
  totalTasks      Int      @map("total_tasks")
  avgQualityScore Decimal? @map("avg_quality_score") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  aiAdvantages    Json?    @map("ai_advantages")
  aiRating        String?  @map("ai_rating") @db.VarChar(20)
  aiSuggestions   Json?    @map("ai_suggestions")
  aiSummary       String?  @map("ai_summary")
  team            Team     @relation(fields: [teamId], references: [id])

  @@unique([teamId, periodType, periodValue])
  @@map("team_statistics")
}

model ProjectStatistic {
  id                String   @id @default(uuid())
  projectId         String   @map("project_id")
  periodType        String   @map("period_type") @db.VarChar(20)
  periodValue       String   @map("period_value") @db.VarChar(10)
  totalContributors Int      @map("total_contributors")
  totalCommits      Int      @map("total_commits")
  totalInsertions   Int      @map("total_insertions")
  totalDeletions    Int      @map("total_deletions")
  totalTasks        Int      @map("total_tasks")
  totalLines        Int      @map("total_lines")
  avgQualityScore   Decimal? @map("avg_quality_score") @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  aiAdvantages      Json?    @map("ai_advantages")
  aiBestPractices   Json?    @map("ai_best_practices")
  aiCommonIssues    Json?    @map("ai_common_issues")
  aiRating          String?  @map("ai_rating") @db.VarChar(20)
  aiSuggestions     Json?    @map("ai_suggestions")
  project           Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, periodType, periodValue])
  @@map("project_statistics")
}

model BugItem {
  id                   String    @id @default(uuid())
  bugNo                String    @unique @map("bug_no") @db.VarChar(50)
  bugName              String    @map("bug_name")
  severity             String    @db.VarChar(20)
  bugStatus            String    @map("bug_status") @db.VarChar(50)
  bugFoundPhase        String?   @map("bug_found_phase") @db.VarChar(50)
  bugTypeNew           Json?     @map("bug_type_new")
  subsystem            Json?
  sprintId             Int?      @map("sprint_id")
  sprintName           String?   @map("sprint_name") @db.VarChar(100)
  fixPerson            String?   @map("fix_person") @db.VarChar(100)
  reporter             String?   @db.VarChar(100)
  createdBy            String?   @map("created_by") @db.VarChar(100)
  dateCreated          DateTime? @map("date_created")
  dateUpdated          DateTime? @map("date_updated")
  fixTimes             Int       @default(0) @map("fix_times")
  handOffsTimes        Int       @default(0) @map("hand_offs_times")
  linkedGroupNoDisplay String?   @map("linked_group_no_display") @db.VarChar(200)
  commitHash           String?   @map("commit_hash") @db.VarChar(40)
  committerName        String?   @map("committer_name") @db.VarChar(100)
  projectName          String?   @map("project_name") @db.VarChar(200)
  periodType           String    @map("period_type") @db.VarChar(20)
  periodValue          String    @map("period_value") @db.VarChar(10)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([periodType, periodValue])
  @@index([fixPerson])
  @@index([severity])
  @@map("bug_items")
}

model BugStatistic {
  id                   String   @id @default(uuid())
  periodType           String   @map("period_type") @db.VarChar(20)
  periodValue          String   @map("period_value") @db.VarChar(10)
  username             String   @db.VarChar(100)
  totalBugs            Int      @map("total_bugs")
  criticalBugs         Int      @default(0) @map("critical_bugs")
  severeBugs           Int      @default(0) @map("severe_bugs")
  normalBugs           Int      @default(0) @map("normal_bugs")
  minorBugs            Int      @default(0) @map("minor_bugs")
  avgFixTimes          Decimal? @map("avg_fix_times") @db.Decimal(5, 2)
  avgHandOffsTimes     Decimal? @map("avg_hand_offs_times") @db.Decimal(5, 2)
  bugTypeDistribution  Json?    @map("bug_type_distribution")
  phaseDistribution    Json?    @map("phase_distribution")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([periodType, periodValue, username])
  @@map("bug_statistics")
}

model BugAnalysisReport {
  id                   String   @id @default(uuid())
  periodType           String   @map("period_type") @db.VarChar(20)
  periodValue          String   @map("period_value") @db.VarChar(10)
  trendSummary         String?  @map("trend_summary")
  topIssueTypes        Json?    @map("top_issue_types")
  highRiskPersons      Json?    @map("high_risk_persons")
  phaseAnalysis        Json?    @map("phase_analysis")
  aiInsights           String?  @map("ai_insights")
  aiSuggestions        Json?    @map("ai_suggestions")
  totalBugs            Int      @default(0) @map("total_bugs")
  severityDistribution Json?    @map("severity_distribution")
  typeDistribution     Json?    @map("type_distribution")
  phaseDistribution    Json?    @map("phase_distribution")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([periodType, periodValue])
  @@map("bug_analysis_reports")
}

model TaskDifficultyScore {
  id          String @id @default(uuid())
  periodType  String @map("period_type") @db.VarChar(20)
  periodValue String @map("period_value") @db.VarChar(10)
  taskNo      String @map("task_no") @db.VarChar(50)
  projectNames Json  @map("project_names")
  committers   Json

  scoreScale        Decimal @map("score_scale") @db.Decimal(5, 2)
  scoreComplexity   Decimal @map("score_complexity") @db.Decimal(5, 2)
  scoreIssueDensity Decimal @map("score_issue_density") @db.Decimal(5, 2)
  scoreAi           Decimal @map("score_ai") @db.Decimal(5, 2)
  scoreCrossModule  Decimal @map("score_cross_module") @db.Decimal(5, 2)
  totalScore        Decimal @map("total_score") @db.Decimal(5, 2)
  difficultyLevel   String  @map("difficulty_level") @db.VarChar(10)

  rawLoc         Int      @map("raw_loc")
  rawCommitCount Int      @map("raw_commit_count")
  rawIssueCount  Int      @map("raw_issue_count")
  rawAvgAiScore  Decimal? @map("raw_avg_ai_score") @db.Decimal(5, 2)
  rawModuleCount Int      @map("raw_module_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([taskNo, periodType, periodValue])
  @@index([periodType, periodValue])
  @@index([difficultyLevel])
  @@map("task_difficulty_scores")
}
