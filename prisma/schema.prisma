generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          String          @id @default(uuid())
  name        String          @db.VarChar(100)
  description String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  leaderName  String?         @map("leader_name") @db.VarChar(50)
  projects    Project[]
  statistics  TeamStatistic[]
  users       User[]

  @@map("teams")
}

model User {
  id               String         @id @default(uuid())
  username         String         @db.VarChar(50)
  email            String         @unique @db.VarChar(100)
  avatar           String?        @db.VarChar(500)
  teamId           String?        @map("team_id")
  gitUsername      String?        @map("git_username") @db.VarChar(100)
  gitEmail         String?        @map("git_email") @db.VarChar(100)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  codeAnalyses     CodeAnalysis[]
  committedReviews CodeReview[]   @relation("CommittedReviews")
  reviewedBy       CodeReview[]   @relation("ReviewedBy")
  team             Team?          @relation(fields: [teamId], references: [id])

  @@map("users")
}

model Project {
  id            String             @id @default(uuid())
  name          String             @db.VarChar(200)
  repository    String             @db.VarChar(500)
  description   String?
  teamId        String?            @map("team_id")
  techStack     Json?              @map("tech_stack")
  isActive      Boolean            @default(true) @map("is_active")
  defaultBranch String?            @map("default_branch") @db.VarChar(100)
  lastCommitAt  DateTime?          @map("last_commit_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  analyses      CodeAnalysis[]
  statistics    ProjectStatistic[]
  team          Team?              @relation(fields: [teamId], references: [id])

  @@map("projects")
}

model CodeAnalysis {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  projectId       String       @map("project_id")
  periodType      String       @map("period_type") @db.VarChar(20)
  periodValue     String       @map("period_value") @db.VarChar(10)
  commitCount     Int          @map("commit_count")
  insertions      Int
  deletions       Int
  filesChanged    Int          @map("files_changed")
  totalLines      Int          @map("total_lines")
  codeLines       Int          @map("code_lines")
  commentLines    Int          @map("comment_lines")
  blankLines      Int          @map("blank_lines")
  languages       Json?
  fileChanges     Json?        @map("file_changes")
  aiQualityScore  Decimal?     @map("ai_quality_score") @db.Decimal(5, 2)
  aiQualityReport String?      @map("ai_quality_report")
  taskCount       Int?         @map("task_count")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  branch          String?      @db.VarChar(100)
  compareVersion  String?      @map("compare_version") @db.VarChar(100)
  currentVersion  String?      @map("current_version") @db.VarChar(100)
  project         Project      @relation(fields: [projectId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
  issues          CodeIssue[]
  reviews         CodeReview[]

  @@unique([userId, projectId, periodType, periodValue])
  @@map("code_analyses")
}

model CodeReview {
  id            String       @id @default(uuid())
  analysisId    String       @map("analysis_id")
  commitHash    String       @map("commit_hash") @db.VarChar(40)
  commitMessage String       @map("commit_message")
  commitBranch  String?      @map("commit_branch") @db.VarChar(200)
  commitDate    DateTime     @map("commit_date")
  committerId   String       @map("committer_id")
  committerName String       @map("committer_name") @db.VarChar(100)
  reviewerId    String?      @map("reviewer_id")
  reviewerName  String?      @map("reviewer_name") @db.VarChar(100)
  status        String       @db.VarChar(20)
  comments      String?
  reviewResult  String?      @map("review_result")
  reviewedAt    DateTime?    @map("reviewed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  analysis      CodeAnalysis @relation(fields: [analysisId], references: [id])
  committer     User         @relation("CommittedReviews", fields: [committerId], references: [id])
  reviewer      User?        @relation("ReviewedBy", fields: [reviewerId], references: [id])

  @@map("code_reviews")
}

model CodeIssue {
  id            String       @id @default(uuid())
  analysisId    String       @map("analysis_id")
  filePath      String       @map("file_path") @db.VarChar(500)
  lineStart     Int?         @map("line_start")
  lineEnd       Int?         @map("line_end")
  issueType     String       @map("issue_type") @db.VarChar(50)
  severity      String       @db.VarChar(10)
  description   String
  suggestion    String?
  codeSnippet   String?      @map("code_snippet")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  codeExample   String?      @map("code_example")
  committerName String?      @map("committer_name") @db.VarChar(100)
  analysis      CodeAnalysis @relation(fields: [analysisId], references: [id])

  @@index([analysisId])
  @@index([severity])
  @@index([issueType])
  @@map("code_issues")
}

model TeamStatistic {
  id              String   @id @default(uuid())
  teamId          String   @map("team_id")
  periodType      String   @map("period_type") @db.VarChar(20)
  periodValue     String   @map("period_value") @db.VarChar(10)
  totalMembers    Int      @map("total_members")
  activeMembers   Int      @map("active_members")
  totalCommits    Int      @map("total_commits")
  totalInsertions Int      @map("total_insertions")
  totalDeletions  Int      @map("total_deletions")
  totalTasks      Int      @map("total_tasks")
  avgQualityScore Decimal? @map("avg_quality_score") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  aiAdvantages    Json?    @map("ai_advantages")
  aiRating        String?  @map("ai_rating") @db.VarChar(20)
  aiSuggestions   Json?    @map("ai_suggestions")
  aiSummary       String?  @map("ai_summary")
  team            Team     @relation(fields: [teamId], references: [id])

  @@unique([teamId, periodType, periodValue])
  @@map("team_statistics")
}

model ProjectStatistic {
  id                String   @id @default(uuid())
  projectId         String   @map("project_id")
  periodType        String   @map("period_type") @db.VarChar(20)
  periodValue       String   @map("period_value") @db.VarChar(10)
  totalContributors Int      @map("total_contributors")
  totalCommits      Int      @map("total_commits")
  totalInsertions   Int      @map("total_insertions")
  totalDeletions    Int      @map("total_deletions")
  totalTasks        Int      @map("total_tasks")
  totalLines        Int      @map("total_lines")
  avgQualityScore   Decimal? @map("avg_quality_score") @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  aiAdvantages      Json?    @map("ai_advantages")
  aiBestPractices   Json?    @map("ai_best_practices")
  aiCommonIssues    Json?    @map("ai_common_issues")
  aiRating          String?  @map("ai_rating") @db.VarChar(20)
  aiSuggestions     Json?    @map("ai_suggestions")
  project           Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, periodType, periodValue])
  @@map("project_statistics")
}
